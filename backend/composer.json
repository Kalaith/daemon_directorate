{
  "name": "webhatchery/daemon-directorate-backend",
  "description": "PHP backend API for Daemon Directorate",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "ext-pdo": "*",
    "firebase/php-jwt": "^6.11",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S 0.0.0.0:8000 -t public",
    "test": "phpunit",
    "cs-check": "phpcs --standard=PSR12 src",
    "cs-fix": "phpcbf --standard=PSR12 src"
  }
}
